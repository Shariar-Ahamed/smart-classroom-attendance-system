# SmartAttend AI - Backend Environment Variables Template
# Copy this file to '.env' in the same folder and configure your local settings.

# MongoDB Connection URI
MONGO_URI=mongodb://localhost:27017

# MongoDB Database Name
DB_NAME=smartattend

# Secret key for signing JWT tokens (use a strong random key in production)
JWT_SECRET=change-me-in-production-use-a-strong-random-key

# Camera source: 0 for default webcam, or an RTSP stream URL for IP cameras
CAMERA_SOURCE=0
